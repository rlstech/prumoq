# syntax=docker/dockerfile:1
# The Expo PWA is built in the GitHub Actions runner (not here) to avoid
# Metro/pnpm symlink resolution issues inside Docker.
# The pre-built dist/ folder is copied directly from the build context.
FROM nginx:alpine
COPY nginx.pwa.conf /etc/nginx/conf.d/default.conf
COPY apps/mobile/dist /usr/share/nginx/html
EXPOSE 80
