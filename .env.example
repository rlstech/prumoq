# ============================================================
# PrumoQ — Environment Variables Template
# Copy to apps/mobile/.env and apps/web/.env.local as needed
# ============================================================

# ── Mobile (apps/mobile/.env) ────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_POWERSYNC_URL=https://your-instance.powersync.journeyapps.com
EXPO_PUBLIC_R2_PUBLIC_URL=https://fotos.prumoq.com.br

# ── Web Admin (apps/web/.env.local) ──────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
POWERSYNC_URL=https://your-instance.powersync.journeyapps.com

# ── Supabase Edge Functions (set via: supabase secrets set) ──
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=prumoq-fotos
